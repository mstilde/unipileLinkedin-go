# ==============================================================================
# unipile-linkedin-go — env de ejemplo
# Copiar a .env y completar. Nunca commitear .env real.
# IMPORTANTE: estas credenciales son NUEVAS, separadas del repo original.
# ==============================================================================

# ---- Server ----
PORT=8080
ENV=development            # development | staging | production
LOG_LEVEL=info             # debug | info | warn | error

# ---- Database (Postgres) ----
# Docker local default. Cambiar si usás Neon/Supabase/Railway.
DATABASE_URL=postgres://unipile:unipile@localhost:5432/unipile_go?sslmode=disable

# ---- Auth ----
# Generar con: openssl rand -base64 48
JWT_SECRET=                # mínimo 32 chars
JWT_SESSION_TTL=168h       # 7 días
JWT_ISSUER=unipile-go
JWT_AUDIENCE=unipile-go

# ---- Unipile (CUENTA NUEVA, no la del repo original) ----
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=    # validar firma de webhooks entrantes

# ---- IA (claves NUEVAS, no las del repo original) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Modelos por defecto (overridable)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
OPENAI_MODEL_ENRICH=gpt-4o-mini

# Cap mensual global de gasto IA (USD)
AI_MONTHLY_CAP_USD=200
MAX_CONCURRENT_AI=5

# ---- Storage ----
STORAGE_DRIVER=fs          # fs | s3
STORAGE_FS_ROOT=./cache

# ---- CORS ----
CORS_ORIGINS=http://localhost:8080

# ---- Schedulers ----
CAMPAIGN_SCHEDULER_INTERVAL=15m
AIQUEUE_INTERVAL=30s
FOLLOWUP_INTERVAL=15m
FOLLOWUP_TZ=America/Argentina/Buenos_Aires
FOLLOWUP_WH_START=9
FOLLOWUP_WH_END=19
FOLLOWUP_SKIP_WEEKENDS=true

# ---- Safety ----
DRY_RUN=true               # true = no envía nada por Unipile, solo loguea
KILLSWITCH_GLOBAL=false
